# ──────────────────────────────────────────────────────────
# YouTube Shorts SEO Agent — Environment Variables Template
# Copy this file to .env and fill in all values
# ──────────────────────────────────────────────────────────

# ── Google Drive (Service Account) ──────────────────────
# Paste the full contents of your service account JSON key as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# The Drive folder ID to scan for videos (from the URL: drive.google.com/drive/folders/<FOLDER_ID>)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── YouTube Data API v3 (OAuth2) ─────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your_youtube_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
# Generate with: python get_youtube_token.py
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token

# ── AI API (choose one) ──────────────────────────────────
# NVIDIA Nemotron (Default)
NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# Anthropic Claude (fallback)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI GPT-4 (fallback — leave blank if using Anthropic)
OPENAI_API_KEY=sk-your_key_here

# ── Telegram Notification ─────────────────────────────────
# Create a bot via @BotFather on Telegram
# Get chat ID from @userinfobot or your channel
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
